{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poststudio-system.dev/integration/schemas/creative-render-request.schema.json",
  "title": "Creative Render Request",
  "description": "Schema for the CRUD platform → rendering worker render-job request.",
  "type": "object",
  "required": ["render_job_id", "tenant_id", "brand_id", "renderable_carousel"],
  "properties": {
    "render_job_id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string" },
    "brand_id": { "type": "string" },
    "job_id": { "type": "string", "description": "Upstream generation job id." },
    "callback_url": { "type": "string", "format": "uri" },
    "callback_signing_secret_id": { "type": "string" },
    "renderable_carousel": {
      "type": "object",
      "description": "Conforms to schemas/renderable-carousel.schema.json"
    },
    "options": {
      "type": "object",
      "properties": {
        "format": { "type": "string", "enum": ["png", "jpg"], "default": "png" },
        "quality": { "type": "string", "enum": ["draft", "standard", "high"], "default": "standard" },
        "concurrency": { "type": "integer", "minimum": 1, "maximum": 16, "default": 4 },
        "background_fallback_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{3,8}$" }
      }
    },
    "asset_resolution": {
      "type": "object",
      "description": "Optional pre-resolved asset map. Worker may also resolve via its own registry.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "type": { "type": "string", "enum": ["image", "font"] }
        }
      }
    }
  }
}
