{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poststudio-system.dev/schemas/monthly-content-plan.schema.json",
  "title": "Monthly Content Plan",
  "description": "Schema for the monthly content plan deliverable.",
  "type": "object",
  "required": ["version", "prompt_version", "brand_slug", "month", "theme", "total_posts", "posts"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "prompt_version": { "type": "string" },
    "brand_slug": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "month": { "type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$" },
    "theme": { "type": "string" },
    "total_posts": { "type": "integer" },
    "channels": {
      "type": "array",
      "items": { "type": "string", "enum": ["linkedin", "instagram", "tiktok", "x", "threads", "multi"] }
    },
    "primary_channel": { "type": "string" },
    "active_campaigns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "start_day": { "type": "integer" },
          "end_day": { "type": "integer" }
        }
      }
    },
    "posts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["day", "topic", "format", "pillar"],
        "properties": {
          "day": { "type": "integer", "minimum": 1, "maximum": 31 },
          "date": { "type": "string", "format": "date" },
          "topic": { "type": "string" },
          "format": { "type": "string", "enum": ["carousel", "reel", "essay", "case_study", "single_image", "thread"] },
          "pillar": { "type": "string" },
          "channel": { "type": "string" },
          "primary_cta": { "type": "string" },
          "status": { "type": "string", "enum": ["planned", "drafted", "in_review", "approved", "scheduled", "published"] },
          "notes": { "type": "string" }
        }
      }
    },
    "required_client_inputs": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "success_metrics": { "type": "array", "items": { "type": "string" } },
    "end_of_month_review_date": { "type": "string", "format": "date" }
  }
}
