{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poststudio-system.dev/schemas/renderable-carousel.schema.json",
  "title": "Renderable Carousel",
  "description": "Renderable carousel JSON: HTML/CSS, SVG, or template-driven JSON ready for a worker to render into PNG/JPG.",
  "type": "object",
  "required": [
    "version",
    "prompt_version",
    "request_id",
    "brand",
    "topic",
    "carousel",
    "slides",
    "caption",
    "cta",
    "first_comment",
    "alternative_hooks",
    "renderability_validated"
  ],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "prompt_version": { "type": "string" },
    "request_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "brand_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "mode": { "type": "string", "const": "renderable-creative-worker" },
    "brand": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "topic": { "type": "string" },
    "platform": {
      "type": "string",
      "enum": ["linkedin", "instagram", "tiktok", "x", "threads", "multi"]
    },
    "language": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
    "goal": { "type": "string" },
    "angle": { "type": "string" },
    "structure": { "type": "string" },
    "carousel": {
      "type": "object",
      "required": ["canvas", "render_mode", "slide_count"],
      "properties": {
        "canvas": {
          "type": "object",
          "required": ["width", "height", "format"],
          "properties": {
            "width": { "type": "integer", "minimum": 256 },
            "height": { "type": "integer", "minimum": 256 },
            "format": { "type": "string", "enum": ["png", "jpg"] }
          }
        },
        "render_mode": {
          "type": "string",
          "enum": ["html-css", "svg", "template"]
        },
        "accent_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{3,8}$" },
        "slide_count": { "type": "integer", "minimum": 1, "maximum": 12 },
        "fonts_required": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["family"],
            "properties": {
              "family": { "type": "string" },
              "fallback_chain": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "assets_required": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["asset_id"],
            "properties": {
              "asset_id": { "type": "string" },
              "purpose": { "type": "string" },
              "required": { "type": "boolean", "default": true }
            }
          }
        }
      }
    },
    "strategic_angle": { "type": "string" },
    "slides": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": { "$ref": "renderable-slide.schema.json" }
    },
    "caption": { "type": "string" },
    "cta": { "type": "string" },
    "first_comment": { "type": "string" },
    "alternative_hooks": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "type": "string" }
    },
    "renderability_validated": { "type": "boolean" },
    "renderability_checks": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["pass", "fail", "risk"]
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "missing_inputs": { "type": "array", "items": { "type": "string" } },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "remediation": { "type": "string" }
        }
      }
    }
  }
}
