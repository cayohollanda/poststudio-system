{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poststudio-system.dev/schemas/visual-style.schema.json",
  "title": "PostStudio Visual Style",
  "description": "Schema for the visual-style component of a Brand Pack. Standalone or referenced from brand-pack.schema.json.",
  "type": "object",
  "required": ["primary_mode", "color_palette", "typography"],
  "additionalProperties": false,
  "properties": {
    "primary_mode": {
      "type": "string",
      "enum": [
        "cinematic-dark",
        "editorial-minimal",
        "futuristic-interface",
        "surreal-product-metaphor",
        "premium-founder-operator",
        "technical-blueprint",
        "exploded-diagram",
        "meme-but-premium"
      ]
    },
    "secondary_mode": {
      "type": ["string", "null"],
      "enum": [
        null,
        "cinematic-dark",
        "editorial-minimal",
        "futuristic-interface",
        "surreal-product-metaphor",
        "premium-founder-operator",
        "technical-blueprint",
        "exploded-diagram",
        "meme-but-premium"
      ]
    },
    "rationale": {
      "type": "string",
      "description": "1-3 sentences on why this primary mode fits the brand."
    },
    "color_palette": {
      "type": "object",
      "required": ["primary", "accent"],
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{3,8}$",
          "description": "Primary brand color used for backgrounds, key surfaces, or main typography in light mode."
        },
        "accent": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{3,8}$",
          "description": "Single accent color used selectively (one element per slide max)."
        },
        "neutrals": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": { "type": "string", "pattern": "^#[0-9A-Fa-f]{3,8}$" }
        },
        "dark_mode_base": { "type": "string", "pattern": "^#[0-9A-Fa-f]{3,8}$" },
        "light_mode_base": { "type": "string", "pattern": "^#[0-9A-Fa-f]{3,8}$" }
      }
    },
    "typography": {
      "type": "object",
      "required": ["headline"],
      "additionalProperties": false,
      "properties": {
        "headline": {
          "type": "string",
          "description": "Headline typeface (e.g. 'Tiempos Headline', 'Söhne', 'GT Sectra')."
        },
        "body": { "type": "string" },
        "mono": { "type": "string" },
        "weight_headline": { "type": "string" },
        "weight_body": { "type": "string" },
        "letter_spacing_headline": { "type": "string" },
        "case_headline": {
          "type": "string",
          "enum": ["sentence", "title", "upper", "lower"]
        }
      }
    },
    "logo_placement": {
      "type": "string",
      "enum": ["bottom-right", "bottom-left", "top-right", "top-left", "hidden"]
    },
    "headline_placement": {
      "type": "string",
      "enum": ["bottom-third", "top-left", "top-right", "right-side", "left-side", "center"]
    },
    "slide_number_style": {
      "type": "string",
      "enum": ["top-right-small", "top-left-small", "hidden"]
    },
    "margins_px": {
      "type": "object",
      "required": ["top", "right", "bottom", "left"],
      "additionalProperties": false,
      "properties": {
        "top": { "type": "integer", "minimum": 0 },
        "right": { "type": "integer", "minimum": 0 },
        "bottom": { "type": "integer", "minimum": 0 },
        "left": { "type": "integer", "minimum": 0 }
      }
    },
    "lighting_defaults": {
      "type": "string",
      "description": "Default lighting language used in image prompts."
    },
    "texture_defaults": {
      "type": "string",
      "description": "Default texture / finish language used in image prompts."
    },
    "depth_defaults": {
      "type": "string",
      "description": "Default depth / focus / atmosphere language used in image prompts."
    },
    "image_prompt_blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "snippet"],
        "properties": {
          "name": { "type": "string" },
          "snippet": { "type": "string" }
        }
      },
      "description": "Reusable, modular fragments the brand combines into image prompts."
    },
    "negative_prompt_defaults": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Strings every image prompt should ALWAYS exclude."
    },
    "example_image_prompts": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string" }
    },
    "platform_aspect_ratios": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "linkedin": { "type": "string" },
        "instagram": { "type": "string" },
        "tiktok": { "type": "string" },
        "x": { "type": "string" },
        "threads": { "type": "string" }
      }
    },
    "do_nots": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Visual decisions that are off-limits for this brand."
    },
    "to_be_decided": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Visual choices intentionally deferred."
    }
  }
}
